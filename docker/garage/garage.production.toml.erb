metadata_dir = "/var/lib/garage/meta"
data_dir     = "/var/lib/garage/data"
db_engine    = "lmdb"

replication_factor = 1

rpc_bind_addr = "[::]:3901"
rpc_secret = "<%= `bin/rails credentials:fetch garage.rpc_secret -e #{ENV['KAMAL_DESTINATION']}`.strip %>"

[s3_api]
api_bind_addr = "[::]:3900"
s3_region     = "garage"

[admin]
api_bind_addr = "[::]:3903"
